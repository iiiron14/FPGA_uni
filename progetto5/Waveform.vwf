/*<simulation_settings>
<ftestbench_cmd>quartus_eda --gen_testbench --tool=modelsim_oem --format=vhdl --write_settings_files=off DATA_ELAB -c DATA_ELAB --vector_source="C:/progetto_elettronica/progetto5/Waveform.vwf" --testbench_file="C:/progetto_elettronica/progetto5/simulation/qsim/Waveform.vwf.vht"</ftestbench_cmd>
<ttestbench_cmd>quartus_eda --gen_testbench --tool=modelsim_oem --format=vhdl --write_settings_files=off DATA_ELAB -c DATA_ELAB --vector_source="C:/progetto_elettronica/progetto5/Waveform.vwf" --testbench_file="C:/progetto_elettronica/progetto5/simulation/qsim/Waveform.vwf.vht"</ttestbench_cmd>
<fnetlist_cmd>quartus_eda --write_settings_files=off --simulation --functional=on --flatten_buses=off --tool=modelsim_oem --format=vhdl --output_directory="C:/progetto_elettronica/progetto5/simulation/qsim/" DATA_ELAB -c DATA_ELAB</fnetlist_cmd>
<tnetlist_cmd>quartus_eda --write_settings_files=off --simulation --functional=off --flatten_buses=off --timescale=1ps --tool=modelsim_oem --format=vhdl --output_directory="C:/progetto_elettronica/progetto5/simulation/qsim/" DATA_ELAB -c DATA_ELAB</tnetlist_cmd>
<modelsim_script>onerror {exit -code 1}
vlib work
vcom -work work DATA_ELAB.vho
vcom -work work Waveform.vwf.vht
vsim -c -t 1ps -L cycloneive -L altera -L altera_mf -L 220model -L sgate -L altera_lnsim work.DATA_ELAB_vhd_vec_tst
vcd file -direction DATA_ELAB.msim.vcd
vcd add -internal DATA_ELAB_vhd_vec_tst/*
vcd add -internal DATA_ELAB_vhd_vec_tst/i1/*
proc simTimestamp {} {
    echo "Simulation time: $::now ps"
    if { [string equal running [runStatus]] } {
        after 2500 simTimestamp
    }
}
after 2500 simTimestamp
run -all
quit -f


</modelsim_script>
<modelsim_script_timing>onerror {exit -code 1}
vlib work
vcom -work work DATA_ELAB.vho
vcom -work work Waveform.vwf.vht
vsim -novopt -c -t 1ps -sdfmax DATA_ELAB_vhd_vec_tst/i1=DATA_ELAB_vhd.sdo -L cycloneive -L altera -L altera_mf -L 220model -L sgate -L altera_lnsim work.DATA_ELAB_vhd_vec_tst
vcd file -direction DATA_ELAB.msim.vcd
vcd add -internal DATA_ELAB_vhd_vec_tst/*
vcd add -internal DATA_ELAB_vhd_vec_tst/i1/*
proc simTimestamp {} {
    echo "Simulation time: $::now ps"
    if { [string equal running [runStatus]] } {
        after 2500 simTimestamp
    }
}
after 2500 simTimestamp
run -all
quit -f


</modelsim_script_timing>
<hdl_lang>vhdl</hdl_lang>
</simulation_settings>*/
